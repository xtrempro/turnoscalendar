{
  "name": "proturnos",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "deploy": "node build.mjs && npm run deploy:hosting:production && npm run deploy:hosting:test",
    "deploy:hosting:production": "firebase deploy --only hosting --project calendarioturnos-7c4d9",
    "deploy:hosting:test": "firebase deploy --only hosting --config firebase.test.json --project turnoplus-test-7c4d9",
    "deploy:security": "node build.mjs && firebase deploy --only firestore:rules,storage,hosting --project calendarioturnos-7c4d9",
    "security:client": "node scripts/verify-client-build.mjs",
    "security:check": "npm run build && npm run security:client && npm run test:hosting-security && npm run test:app-check",
    "security:appcheck:test": "node scripts/configure-test-app-check.mjs",
    "security:appcheck:test:apply": "node scripts/configure-test-app-check.mjs --apply",
    "test:state-modules": "node --test tests/state-modules.test.mjs",
    "test:shift-assignment": "node --test tests/shift-assignment-history.test.mjs",
    "test:replacement-leaves": "node --test tests/replacement-leave-grouping.test.mjs",
    "test:replacement-candidates": "node --test tests/replacement-contract-candidates.test.mjs",
    "test:replacement-rotation": "node --test tests/replacement-rotation.test.mjs",
    "test:calendar-rotation-month": "node --test tests/calendar-rotation-month.test.mjs",
    "test:calendar-direct-edit": "node --test tests/calendar-direct-edit.test.mjs",
    "test:swap-receivers": "node --test tests/swap-receiver-filter.test.mjs",
    "test:worker-app-unlink": "node --test tests/worker-app-unlink.test.mjs",
    "test:worker-app-sync": "node --test tests/worker-app-publish-queue.test.mjs",
    "test:worker-app-months": "node --test tests/worker-app-months.test.mjs",
    "test:incremental-render": "node --test tests/frontend-incremental-render.test.mjs",
    "test:worker": "node --test tests/schedule-worker.test.mjs",
    "test:linked-units": "node --test tests/linked-units-on-demand.test.mjs",
    "test:leave-application": "node --test tests/leave-application.test.mjs",
    "test:profile-leave-history": "node --test tests/profile-leave-history.test.mjs",
    "test:hosting-security": "node --test tests/hosting-security-config.test.mjs",
    "test:app-check": "node --test tests/firebase-app-check-config.test.mjs",
    "test:self-test": "node --test tests/self-test.test.mjs",
    "test:main-thread": "node --test tests/main-thread-scheduler.test.mjs",
    "test:pwa": "node --test tests/pwa-install.test.mjs",
    "test:rules": "firebase emulators:exec --project demo-proturnos --only firestore,storage \"node --test tests/security-rules.test.mjs\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "esbuild": "^0.28.1",
    "firebase": "^12.15.0"
  }
}
