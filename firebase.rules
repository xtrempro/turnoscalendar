rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasMfa() {
      return signedIn() &&
        request.auth.token.firebase != null &&
        "sign_in_second_factor" in request.auth.token.firebase &&
        request.auth.token.firebase.sign_in_second_factor != null;
    }

    function mfaRequirementActive() {
      // TOTP queda listo para reactivarse, pero no se exige en esta etapa
      // comercial inicial.
      return false;
    }

    function memberData(workspaceId) {
      return get(
        /databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)
      ).data;
    }

    function memberRequiresMfa(workspaceId) {
      let member = memberData(workspaceId);
      let permissions =
        "permissions" in member ? member.permissions : {};

      return member.role == "owner" ||
        ("turnos" in permissions && permissions.turnos.edit == true) ||
        ("weekly" in permissions && permissions.weekly.edit == true) ||
        ("tasks" in permissions && permissions.tasks.edit == true) ||
        ("kanban" in permissions && permissions.kanban.edit == true) ||
        ("agenda" in permissions && permissions.agenda.edit == true) ||
        ("profile" in permissions && permissions.profile.edit == true) ||
        ("clockmarks" in permissions && permissions.clockmarks.edit == true) ||
        ("requests" in permissions && permissions.requests.edit == true) ||
        ("memos" in permissions && permissions.memos.edit == true) ||
        ("swap" in permissions && permissions.swap.edit == true) ||
        ("hours" in permissions && permissions.hours.edit == true) ||
        ("reports" in permissions && permissions.reports.edit == true) ||
        ("dashboard" in permissions && permissions.dashboard.edit == true) ||
        ("log" in permissions && permissions.log.edit == true);
    }

    function memberHasExplicitAccess(workspaceId) {
      let member = memberData(workspaceId);

      return member.role == "owner" ||
        (
          member.role == "member" &&
          "permissions" in member &&
          member.permissions is map
        );
    }

    function isMember(workspaceId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)) &&
        memberHasExplicitAccess(workspaceId) &&
        (
          !mfaRequirementActive() ||
          !memberRequiresMfa(workspaceId) ||
          hasMfa()
        );
    }

    function workspaceExists(workspaceId) {
      return exists(/databases/$(database)/documents/workspaces/$(workspaceId));
    }

    function isOwner(workspaceId) {
      return isMember(workspaceId) &&
        memberData(workspaceId).role == "owner";
    }

    function isLinkedWorker(workspaceId, userId) {
      return signedIn() &&
        request.auth.uid == userId &&
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(userId));
    }

    function workerLinkExists(workspaceId, userId) {
      return exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(userId));
    }

    function isCurrentLinkedWorker(workspaceId) {
      return signedIn() &&
        workerLinkExists(workspaceId, request.auth.uid);
    }

    function canAccessWorkerPeerThread(workspaceId, threadId) {
      return isCurrentLinkedWorker(workspaceId) &&
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerPeerThreads/$(threadId)) &&
        request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)/workerPeerThreads/$(threadId)).data.participantUids;
    }

    function canAccessWorkerPeerThreadAfter(workspaceId, threadId) {
      return isCurrentLinkedWorker(workspaceId) &&
        existsAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerPeerThreads/$(threadId)) &&
        request.auth.uid in getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerPeerThreads/$(threadId)).data.participantUids;
    }

    function canMemberWriteWorkspaceState(workspaceId) {
      let member =
        get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data;
      let permissions =
        "permissions" in member ? member.permissions : {};

      return isMember(workspaceId) &&
        (
          member.role == "owner" ||
          ("turnos" in permissions && permissions.turnos.edit == true) ||
          ("weekly" in permissions && permissions.weekly.edit == true) ||
          ("tasks" in permissions && permissions.tasks.edit == true) ||
          ("kanban" in permissions && permissions.kanban.edit == true) ||
          ("agenda" in permissions && permissions.agenda.edit == true) ||
          ("profile" in permissions && permissions.profile.edit == true) ||
          ("clockmarks" in permissions && permissions.clockmarks.edit == true) ||
          ("requests" in permissions && permissions.requests.edit == true) ||
          ("memos" in permissions && permissions.memos.edit == true) ||
          ("swap" in permissions && permissions.swap.edit == true) ||
          ("hours" in permissions && permissions.hours.edit == true) ||
          ("reports" in permissions && permissions.reports.edit == true) ||
          ("log" in permissions && permissions.log.edit == true)
        );
    }

    function canManageProfiles(workspaceId) {
      let member =
        get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data;
      let permissions =
        "permissions" in member ? member.permissions : {};

      return isMember(workspaceId) &&
        (
          member.role == "owner" ||
          ("profile" in permissions && permissions.profile.edit == true)
        );
    }

    function canManageRequests(workspaceId) {
      let member =
        get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data;
      let permissions =
        "permissions" in member ? member.permissions : {};

      return isMember(workspaceId) &&
        (
          member.role == "owner" ||
          ("requests" in permissions && permissions.requests.edit == true) ||
          ("turnos" in permissions && permissions.turnos.edit == true)
        );
    }

    function canEditMenu(workspaceId, menuKey) {
      let member =
        get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data;
      let permissions =
        "permissions" in member ? member.permissions : {};

      return isMember(workspaceId) &&
        (
          member.role == "owner" ||
          (
            menuKey in permissions &&
            permissions[menuKey].edit == true
          )
        );
    }

    function canViewMenu(workspaceId, menuKey) {
      let member =
        get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data;
      let permissions =
        "permissions" in member ? member.permissions : {};

      return isMember(workspaceId) &&
        (
          member.role == "owner" ||
          (
            menuKey in permissions &&
            permissions[menuKey].view == true
          )
        );
    }

    function canReadStateModule(workspaceId, moduleId) {
      return isOwner(workspaceId) ||
        (moduleId == "profile" && canViewMenu(workspaceId, "profile")) ||
        (moduleId == "turnos" && canViewMenu(workspaceId, "turnos")) ||
        (moduleId == "clockmarks" && canViewMenu(workspaceId, "clockmarks")) ||
        (moduleId == "requests" && canViewMenu(workspaceId, "requests")) ||
        (moduleId == "memos" && canViewMenu(workspaceId, "memos")) ||
        (moduleId == "swap" && canViewMenu(workspaceId, "swap")) ||
        (moduleId == "hours" && canViewMenu(workspaceId, "hours")) ||
        (moduleId == "weekly" && canViewMenu(workspaceId, "weekly")) ||
        (moduleId == "tasks" && canViewMenu(workspaceId, "tasks")) ||
        (moduleId == "agenda" && canViewMenu(workspaceId, "agenda")) ||
        (moduleId == "reports" && canViewMenu(workspaceId, "reports")) ||
        (moduleId == "log" && canViewMenu(workspaceId, "log"));
    }

    function canWriteStateModule(workspaceId, moduleId) {
      return isOwner(workspaceId) ||
        (moduleId == "profile" && canEditMenu(workspaceId, "profile")) ||
        (moduleId == "turnos" && canEditMenu(workspaceId, "turnos")) ||
        (moduleId == "clockmarks" && canEditMenu(workspaceId, "clockmarks")) ||
        (moduleId == "requests" && canEditMenu(workspaceId, "requests")) ||
        (moduleId == "memos" && canEditMenu(workspaceId, "memos")) ||
        (moduleId == "swap" && canEditMenu(workspaceId, "swap")) ||
        (moduleId == "hours" && canEditMenu(workspaceId, "hours")) ||
        (moduleId == "weekly" && canEditMenu(workspaceId, "weekly")) ||
        (moduleId == "tasks" && canEditMenu(workspaceId, "tasks")) ||
        (moduleId == "agenda" && canEditMenu(workspaceId, "agenda")) ||
        (moduleId == "reports" && canEditMenu(workspaceId, "reports")) ||
        (moduleId == "log" && canEditMenu(workspaceId, "log"));
    }

    function validText(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function optionalText(data, key, maxLength) {
      return !(key in data) || validText(data[key], maxLength);
    }

    function canCreateOwnWorkspaceMember(workspaceId, userId) {
      return signedIn() &&
        userId == request.auth.uid &&
        workspaceExists(workspaceId) &&
        request.resource.data.role == "owner" &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerUid == request.auth.uid &&
        (!mfaRequirementActive() || hasMfa());
    }

    function workerInviteNotExpired() {
      return !("expiresAt" in resource.data) ||
        resource.data.expiresAt > request.time;
    }

    function workerInviteEmailAuthRequired() {
      // Modo promocional: el token del enlace de invitacion permite vincular
      // sin enviar un segundo correo de autenticacion. Cambiar a true para
      // exigir que el trabajador confirme su email con Firebase Auth.
      return false;
    }

    function canReadWorkerInvite(inviteId) {
      return signedIn() &&
        resource.data.token == inviteId &&
        resource.data.status == "pending" &&
        workerInviteNotExpired();
    }

    function canAcceptWorkerInvite(workspaceId, inviteId) {
      return canReadWorkerInvite(inviteId) &&
        request.resource.data.workspaceId == workspaceId &&
        request.resource.data.token == inviteId &&
        request.resource.data.status == "accepted" &&
        request.resource.data.workerUid == request.auth.uid &&
        (
          (
            workerInviteEmailAuthRequired() &&
            request.auth.token.email != null &&
            request.resource.data.workerEmail == request.auth.token.email
          ) ||
          (
            !workerInviteEmailAuthRequired() &&
            request.resource.data.workerEmail == resource.data.email
          )
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "workerUid",
          "workerEmail",
          "workerDisplayName",
          "acceptedAt",
          "updatedAt"
        ]);
    }

    function acceptedWorkerInviteAfter(workspaceId, inviteId, userId) {
      return existsAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerAppInvites/$(inviteId)) &&
        getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerAppInvites/$(inviteId)).data.workspaceId == workspaceId &&
        getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerAppInvites/$(inviteId)).data.token == inviteId &&
        getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerAppInvites/$(inviteId)).data.status == "accepted" &&
        getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerAppInvites/$(inviteId)).data.workerUid == userId &&
        (
          (
            workerInviteEmailAuthRequired() &&
            request.auth.token.email != null &&
            getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerAppInvites/$(inviteId)).data.workerEmail == request.auth.token.email
          ) ||
          (
            !workerInviteEmailAuthRequired() &&
            getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerAppInvites/$(inviteId)).data.workerEmail ==
              getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerAppInvites/$(inviteId)).data.email
          )
        );
    }

    function linkIdentityUnchanged() {
      return request.resource.data.fromWorkspaceId == resource.data.fromWorkspaceId &&
        request.resource.data.toWorkspaceId == resource.data.toWorkspaceId &&
        request.resource.data.requestedByUid == resource.data.requestedByUid;
    }

    function canResolveWorkspaceLink() {
      return resource.data.status == "pending" &&
        isMember(resource.data.toWorkspaceId) &&
        request.resource.data.status in ["accepted", "rejected"] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "toWorkspaceName",
          "acceptedAt",
          "acceptedByUid",
          "acceptedByName",
          "rejectedAt",
          "rejectedByUid",
          "rejectedByName",
          "rejectReason",
          "updatedAt"
        ]);
    }

    function canUnlinkWorkspaceLink() {
      return resource.data.status == "accepted" &&
        request.resource.data.status == "unlinked" &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "unlinkedAt",
          "unlinkedByUid",
          "unlinkedByName",
          "updatedAt"
        ]) &&
        (
          isMember(resource.data.fromWorkspaceId) ||
          isMember(resource.data.toWorkspaceId)
        );
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;

      match /workspaces/{workspaceId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /workerLinks/{workspaceId} {
        allow read, create, update: if signedIn() &&
          request.auth.uid == userId;
        allow delete: if signedIn() &&
          (
            request.auth.uid == userId ||
            canManageProfiles(workspaceId)
          );
      }
    }

    // Suscripcion/plan de la cuenta del dueño. Solo el dueño puede leer su
    // documento; la escritura es exclusiva del backend (Cloud Functions con
    // privilegios de admin), para que el plan no se pueda alterar desde el
    // cliente. El conteo de uso lo entrega la function getAccountUsage.
    match /accounts/{ownerUid} {
      allow read: if signedIn() && request.auth.uid == ownerUid;
      allow write: if false;
    }

    // Cupones: toda lectura/escritura pasa por Cloud Functions (admin SDK).
    // Crear/listar/desactivar es solo del admin; canjear escribe accounts via
    // la function redeemCoupon. El cliente nunca accede directo.
    match /coupons/{code} {
      allow read, write: if false;
    }

    // Config global (flag de gating, etc.): solo via Cloud Functions.
    match /config/{doc} {
      allow read, write: if false;
    }

    // Pagos (Webpay/MercadoPago): solo via Cloud Functions (admin SDK). El
    // cliente nunca lee/escribe; recibe token/url por la function y vuelve por
    // el retorno publico.
    match /payments/{buyOrder} {
      allow read, write: if false;
    }

    match /workspaceLinks/{linkId} {
      allow create: if signedIn() &&
        request.resource.data.fromWorkspaceId is string &&
        request.resource.data.toWorkspaceId is string &&
        request.resource.data.fromWorkspaceId != request.resource.data.toWorkspaceId &&
        request.resource.data.status == "pending" &&
        request.resource.data.requestedByUid == request.auth.uid &&
        optionalText(request.resource.data, "fromWorkspaceName", 160) &&
        optionalText(request.resource.data, "toWorkspaceName", 160) &&
        optionalText(request.resource.data, "requestedByName", 160) &&
        isMember(request.resource.data.fromWorkspaceId) &&
        workspaceExists(request.resource.data.toWorkspaceId);

      allow read: if isMember(resource.data.fromWorkspaceId) ||
        isMember(resource.data.toWorkspaceId);

      allow update: if linkIdentityUnchanged() &&
        (
          canResolveWorkspaceLink() ||
          canUnlinkWorkspaceLink()
        );

      allow delete: if false;
    }

    match /workerAppEmailInvites/{emailKey}/items/{inviteId} {
      // Un trabajador solo puede leer las invitaciones dirigidas a SU propio
      // correo (la clave del documento es el email normalizado en minusculas).
      // El supervisor no lee esta coleccion (solo escribe/borra), por lo que no
      // necesita acceso de lectura aqui. Antes era "if signedIn()", lo que
      // permitia a cualquier usuario enumerar invitaciones de cualquier correo.
      allow read: if signedIn() &&
        request.auth.token.email != null &&
        emailKey == request.auth.token.email.lower();
      allow create, update: if signedIn() &&
        request.resource.data.workspaceId is string &&
        validText(request.resource.data.email, 254) &&
        validText(request.resource.data.token, 160) &&
        request.resource.data.token == inviteId &&
        request.resource.data.emailKey == emailKey &&
        request.resource.data.email.lower() == emailKey &&
        request.resource.data.createdByUid == request.auth.uid &&
        optionalText(request.resource.data, "profileName", 160) &&
        optionalText(request.resource.data, "workspaceName", 160) &&
        canManageProfiles(request.resource.data.workspaceId);
      allow delete: if signedIn() &&
        resource.data.workspaceId is string &&
        canManageProfiles(resource.data.workspaceId);
    }

    match /workspaces/{workspaceId} {
      allow create: if signedIn() &&
        (!mfaRequirementActive() || hasMfa()) &&
        request.resource.data.ownerUid == request.auth.uid &&
        !("inviteCode" in request.resource.data);
      allow get: if isMember(workspaceId);
      allow list: if false;
      allow update: if isOwner(workspaceId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            "name",
            "updatedAt",
            "deletionStatus",
            "deletionRequestedAt",
            "deletionRequestedByUid",
            "deletionScheduledAt",
            "deletionCanceledAt"
          ]);
      allow delete: if isOwner(workspaceId);

      match /members/{userId} {
        allow get: if signedIn() &&
          (request.auth.uid == userId || isOwner(workspaceId));
        allow list: if isOwner(workspaceId);
        allow create: if canCreateOwnWorkspaceMember(workspaceId, userId);
        allow update, delete: if isOwner(workspaceId);
      }

      match /supervisorInvites/{inviteId} {
        allow get: if isOwner(workspaceId) ||
          (
            signedIn() &&
            resource.data.claimedByUid == request.auth.uid
          );
        allow list: if isOwner(workspaceId);
        allow create, update, delete: if false;
      }

      match /system/appState {
        allow read, write: if false;
      }

      match /appStateChunks/{chunkId} {
        allow read, write: if false;
      }

      match /stateModules/{moduleId} {
        allow read: if canReadStateModule(workspaceId, moduleId);
        allow create, update: if
          canWriteStateModule(workspaceId, moduleId) &&
          request.resource.data.moduleId == moduleId &&
          request.resource.data.permission is string &&
          request.resource.data.chunkCount is int &&
          request.resource.data.chunkCount >= 1 &&
          request.resource.data.chunkCount <= 100 &&
          request.resource.data.charCount is int &&
          request.resource.data.charCount >= 0 &&
          request.resource.data.hash is string &&
          request.resource.data.hash.size() <= 160;
        allow delete: if canWriteStateModule(workspaceId, moduleId);

        match /chunks/{chunkId} {
          allow read: if canReadStateModule(workspaceId, moduleId);
          allow create, update: if
            canWriteStateModule(workspaceId, moduleId) &&
            request.resource.data.moduleId == moduleId &&
            request.resource.data.index is int &&
            request.resource.data.index >= 0 &&
            request.resource.data.index < 100 &&
            request.resource.data.text is string &&
            request.resource.data.text.size() <= 450000;
          allow delete: if canWriteStateModule(workspaceId, moduleId);
        }
      }

      // Proyeccion operativa minima para prestamos. Una unidad enlazada solo
      // ve nombre, profesion, turnos y disponibilidad del mes; nunca accede al
      // snapshot completo, RUT, correo, documentos, permisos ni configuracion.
      match /linkedStaffingMonths/{monthId} {
        allow read: if isMember(workspaceId);
        allow create, update: if
          isMember(workspaceId) &&
          canMemberWriteWorkspaceState(workspaceId) &&
          request.resource.data.workspaceId == workspaceId &&
          request.resource.data.month == monthId &&
          request.resource.data.workers is list &&
          request.resource.data.workers.size() <= 500;
        allow delete: if isMember(workspaceId) &&
          canMemberWriteWorkspaceState(workspaceId);
      }

      // Solo las Cloud Functions crean o anulan estos documentos. Los clientes
      // autenticados de cada unidad pueden leer su propia proyeccion.
      match /loanAssignments/{loanId} {
        allow read: if isMember(workspaceId);
        allow write: if false;
      }

      match /system/localStorageSnapshot {
        allow read: if isMember(workspaceId);
        allow write: if false;
      }

      match /profiles/{profileId} {
        allow read: if isMember(workspaceId);
        allow write: if canManageProfiles(workspaceId);
      }

      match /replacementRequests/{requestId} {
        allow read: if isMember(workspaceId) ||
          (signedIn() && resource.data.workerUid == request.auth.uid);
        allow create, delete: if canManageRequests(workspaceId);
        allow update: if canManageRequests(workspaceId) ||
          (
            signedIn() &&
            resource.data.workerUid == request.auth.uid &&
            request.resource.data.workerUid == resource.data.workerUid &&
            resource.data.status == "pending" &&
            request.resource.data.status in ["accepted", "rejected"] &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "status",
              "acceptedAt",
              "rejectedAt",
              "responseAt",
              "notificationStatus",
              "updatedAt"
            ])
          );
      }

      match /workerBlockedDays/{blockedDayId} {
        allow read: if isMember(workspaceId) ||
          (signedIn() && resource.data.workerUid == request.auth.uid);
        allow create: if canManageRequests(workspaceId) ||
          (
            signedIn() &&
            request.resource.data.workerUid == request.auth.uid &&
            request.resource.data.workspaceId == workspaceId &&
            request.resource.data.source == "worker_app" &&
            request.resource.data.date is string &&
            blockedDayId == request.auth.uid + "_" + request.resource.data.date &&
            request.resource.data.status == "active" &&
            optionalText(request.resource.data, "reason", 500) &&
            optionalText(request.resource.data, "supervisorMessage", 2000) &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
        allow update: if canManageRequests(workspaceId) ||
          (
            signedIn() &&
            resource.data.workerUid == request.auth.uid &&
            request.resource.data.workerUid == request.auth.uid &&
            request.resource.data.workspaceId == workspaceId &&
            request.resource.data.source == "worker_app" &&
            request.resource.data.date is string &&
            blockedDayId == request.auth.uid + "_" + request.resource.data.date &&
            optionalText(request.resource.data, "reason", 500) &&
            optionalText(request.resource.data, "supervisorMessage", 2000) &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
        allow delete: if canManageRequests(workspaceId) ||
          (
            signedIn() &&
            resource.data.workerUid == request.auth.uid &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
      }

      match /workerRequests/{requestId} {
        allow read: if isMember(workspaceId) ||
          (
            signedIn() &&
            (
              resource.data.createdByUid == request.auth.uid ||
              resource.data.targetUid == request.auth.uid
            ) &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
        allow create: if canManageRequests(workspaceId) ||
          (
            signedIn() &&
            request.resource.data.createdByUid == request.auth.uid &&
            request.resource.data.status in ["pending", "active"] &&
            request.resource.data.source == "worker_app" &&
            validText(request.resource.data.type, 60) &&
            optionalText(request.resource.data, "note", 2000) &&
            optionalText(request.resource.data, "detail", 2000) &&
            optionalText(request.resource.data, "rejectReason", 1000) &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
        allow update: if (
            canManageRequests(workspaceId) &&
            (
              resource.data.status != "canceled" ||
              request.resource.data.status == "canceled"
            )
          ) || (
            // El trabajador puede ANULAR (status -> "canceled") una solicitud
            // propia que siga pendiente, creada desde la app. No puede cambiar
            // el tipo, el autor ni tocar solicitudes ajenas o ya resueltas.
            signedIn() &&
            resource.data.createdByUid == request.auth.uid &&
            resource.data.source == "worker_app" &&
            resource.data.status == "pending" &&
            request.resource.data.status == "canceled" &&
            request.resource.data.createdByUid == resource.data.createdByUid &&
            request.resource.data.type == resource.data.type &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
        allow delete: if canManageRequests(workspaceId);
      }

      match /workerSwapCandidates/{userId} {
        allow read: if isMember(workspaceId) ||
          (
            signedIn() &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
        allow create, update, delete: if
          isMember(workspaceId) &&
          canMemberWriteWorkspaceState(workspaceId);
      }

      match /workerMessageDirectory/{userId} {
        allow read: if isMember(workspaceId) ||
          isCurrentLinkedWorker(workspaceId);
        allow create, update, delete: if
          isMember(workspaceId) &&
          canMemberWriteWorkspaceState(workspaceId);
      }

      match /workerPeerThreads/{threadId} {
        allow read: if canAccessWorkerPeerThread(workspaceId, threadId);
        allow create: if
          (
            isCurrentLinkedWorker(workspaceId) &&
            request.resource.data.workspaceId == workspaceId &&
            request.resource.data.createdByUid == request.auth.uid &&
            request.resource.data.targetUid is string &&
            request.resource.data.targetUid != request.auth.uid &&
            workerLinkExists(workspaceId, request.resource.data.targetUid) &&
            request.resource.data.participantUids is list &&
            request.resource.data.participantUids.size() == 2 &&
            request.auth.uid in request.resource.data.participantUids &&
            request.resource.data.targetUid in request.resource.data.participantUids
          );
        allow update: if
          (
            isCurrentLinkedWorker(workspaceId) &&
            request.auth.uid in resource.data.participantUids &&
            request.resource.data.workspaceId == resource.data.workspaceId &&
            request.resource.data.participantUids == resource.data.participantUids
          );
        allow delete: if isOwner(workspaceId);

        match /messages/{messageId} {
          allow read: if canAccessWorkerPeerThread(workspaceId, threadId);
          allow create: if
            (
              isCurrentLinkedWorker(workspaceId) &&
              canAccessWorkerPeerThreadAfter(workspaceId, threadId) &&
              request.resource.data.workspaceId == workspaceId &&
              request.resource.data.threadId == threadId &&
              request.resource.data.senderUid == request.auth.uid &&
              request.resource.data.targetUid is string &&
              request.resource.data.targetUid != request.auth.uid &&
              validText(request.resource.data.text, 2000) &&
              optionalText(request.resource.data, "senderName", 160) &&
              request.resource.data.targetUid in getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)/workerPeerThreads/$(threadId)).data.participantUids &&
              workerLinkExists(workspaceId, request.resource.data.targetUid)
            );
          allow update, delete: if isOwner(workspaceId);
        }
      }

      match /workerSwapRequests/{requestId} {
        allow read: if isMember(workspaceId) ||
          (
            signedIn() &&
            (
              resource.data.createdByUid == request.auth.uid ||
              resource.data.targetUid == request.auth.uid
            ) &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
        allow create: if canManageRequests(workspaceId) ||
          (
            signedIn() &&
            request.resource.data.createdByUid == request.auth.uid &&
            request.resource.data.targetUid is string &&
            request.resource.data.targetUid != request.auth.uid &&
            request.resource.data.workspaceId == workspaceId &&
            request.resource.data.source == "worker_app" &&
            request.resource.data.type == "swap" &&
            request.resource.data.status == "pending_colleague" &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid)) &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.resource.data.targetUid))
          );
        allow update: if
          (
            canManageRequests(workspaceId) &&
            (
              resource.data.status != "canceled" ||
              request.resource.data.status == "canceled"
            )
          ) ||
          (
            signedIn() &&
            resource.data.targetUid == request.auth.uid &&
            request.resource.data.targetUid == resource.data.targetUid &&
            request.resource.data.createdByUid == resource.data.createdByUid &&
            resource.data.status == "pending_colleague" &&
            request.resource.data.status in ["colleague_accepted", "colleague_rejected"] &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "status",
              "colleagueAcceptedAt",
              "colleagueRejectedAt",
              "colleagueResponseAt",
              "rejectReason",
              "notificationStatus",
              "returnDate",
              "devolucion",
              "returnTurnLabel",
              "updatedAt"
            ]) &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
        allow delete: if canManageRequests(workspaceId);
      }

      match /workerSwapOpenRequests/{openId} {
        allow read: if isMember(workspaceId) ||
          (
            signedIn() &&
            resource.data.createdByUid == request.auth.uid &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
        allow create: if canManageRequests(workspaceId) ||
          (
            signedIn() &&
            request.resource.data.createdByUid == request.auth.uid &&
            request.resource.data.workspaceId == workspaceId &&
            request.resource.data.source == "worker_app" &&
            request.resource.data.status == "open" &&
            request.resource.data.ownDate is string &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(request.auth.uid))
          );
        allow update: if canManageRequests(workspaceId) &&
          (
            resource.data.status != "canceled" ||
            request.resource.data.status == "canceled"
          );
        allow delete: if canManageRequests(workspaceId);
      }

      match /workerAppInvites/{inviteId} {
        allow create: if isMember(workspaceId) &&
          request.resource.data.workspaceId == workspaceId &&
          request.resource.data.token == inviteId &&
          request.resource.data.status == "pending" &&
          validText(request.resource.data.email, 254) &&
          request.resource.data.createdByUid == request.auth.uid &&
          optionalText(request.resource.data, "profileName", 160) &&
          optionalText(request.resource.data, "workspaceName", 160) &&
          optionalText(request.resource.data, "inviteUrl", 2048) &&
          canManageProfiles(workspaceId);
        allow get: if canManageProfiles(workspaceId) ||
          canReadWorkerInvite(inviteId);
        allow list: if canManageProfiles(workspaceId);
        allow update: if canManageProfiles(workspaceId) ||
          canAcceptWorkerInvite(workspaceId, inviteId);
        allow delete: if canManageProfiles(workspaceId);
      }

      match /workerLinks/{userId} {
        allow read: if isMember(workspaceId) ||
          (signedIn() && request.auth.uid == userId);
        allow create, update: if (
          canManageProfiles(workspaceId) &&
          request.resource.data.uid == userId
        ) || (
          signedIn() &&
          request.auth.uid == userId &&
          request.resource.data.uid == userId &&
          request.resource.data.workspaceId == workspaceId &&
          request.resource.data.inviteId is string &&
          acceptedWorkerInviteAfter(
            workspaceId,
            request.resource.data.inviteId,
            userId
          )
        );
        allow delete: if canManageProfiles(workspaceId);
      }

      match /workerPushTokens/{userId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create, update: if signedIn() &&
          request.auth.uid == userId &&
          exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(userId)) &&
          request.resource.data.uid == userId &&
          request.resource.data.workspaceId == workspaceId;
        allow delete: if canManageProfiles(workspaceId) ||
          (signedIn() && request.auth.uid == userId);

        match /tokens/{tokenId} {
          allow read: if signedIn() && request.auth.uid == userId;
          allow create, update: if signedIn() &&
            request.auth.uid == userId &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(userId)) &&
            request.resource.data.uid == userId &&
            request.resource.data.workspaceId == workspaceId &&
            request.resource.data.token is string &&
            request.resource.data.token.size() <= 4096 &&
            request.resource.data.active is bool;
          allow delete: if canManageProfiles(workspaceId) ||
            (signedIn() && request.auth.uid == userId);
        }
      }

      match /workerMessages/{userId} {
        allow read: if canManageRequests(workspaceId) ||
          (signedIn() && request.auth.uid == userId);
        allow create, update: if canManageRequests(workspaceId) ||
          (
            signedIn() &&
            request.auth.uid == userId &&
            exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(userId)) &&
            request.resource.data.uid == userId &&
            request.resource.data.workspaceId == workspaceId
          );
        allow delete: if canManageRequests(workspaceId);

        match /messages/{messageId} {
          allow read: if canManageRequests(workspaceId) ||
            (signedIn() && request.auth.uid == userId);
          allow create: if validText(request.resource.data.text, 2000) &&
            (
              canManageRequests(workspaceId) ||
              (
              signedIn() &&
              request.auth.uid == userId &&
              exists(/databases/$(database)/documents/workspaces/$(workspaceId)/workerLinks/$(userId)) &&
              request.resource.data.workerUid == userId &&
              request.resource.data.workspaceId == workspaceId &&
              validText(request.resource.data.text, 2000)
              )
            );
          allow update, delete: if canManageRequests(workspaceId);
        }
      }

      match /workerAppData/{userId} {
        allow get: if isMember(workspaceId) ||
          isLinkedWorker(workspaceId, userId);
        allow list: if isMember(workspaceId);
        allow create: if
          (isMember(workspaceId) && canMemberWriteWorkspaceState(workspaceId)) ||
          (
            isLinkedWorker(workspaceId, userId) &&
            request.resource.data.keys().hasOnly([
              "blockedDayDates",
              "blockedDays",
              "blockedDaysUpdatedAt",
              "swapOptIn",
              "swapOptInUpdatedAt",
              "updatedAt"
            ])
          );
        allow update: if
          (isMember(workspaceId) && canMemberWriteWorkspaceState(workspaceId)) ||
          (
            isLinkedWorker(workspaceId, userId) &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "blockedDayDates",
              "blockedDays",
              "blockedDaysUpdatedAt",
              "swapOptIn",
              "swapOptInUpdatedAt",
              "updatedAt"
            ])
          );
        allow delete: if
          isMember(workspaceId) &&
          canMemberWriteWorkspaceState(workspaceId);

        match /months/{monthId} {
          allow read: if isMember(workspaceId) ||
            isLinkedWorker(workspaceId, userId);
          allow write: if
            isMember(workspaceId) &&
            canMemberWriteWorkspaceState(workspaceId);
        }
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
}
